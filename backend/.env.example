# =============================================
# CSEA Event Management System — Environment
# Copy this file to .env and fill in values
# =============================================

# ── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────
# Primary: MongoDB Atlas (cloud)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/csea_events?retryWrites=true&w=majority

# Fallback: leave MONGO_URI commented out and set this instead for local MongoDB
# MONGO_URI=mongodb://localhost:27017/csea_events

# ── JWT ──────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=1d
